# ==============================================================================
# AI Intraday Trading Tester System — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file or real secrets to version control.
# For GitHub Actions, set these as repository secrets.
# ==============================================================================

# --- Telegram Alerts (optional) ---
# Create a bot via @BotFather on Telegram, then get the token.
# Send a message to your bot and retrieve chat_id from:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
BOT_TOKEN=
CHAT_ID=

# --- Google Sheets Integration (optional) ---
# Path to service account JSON file (local), OR inline JSON string (CI/CD).
# If empty or file not found, the system falls back to data/mock_signals.csv.
GOOGLE_SERVICE_ACCOUNT_JSON=

# URL of the Google Sheet containing trading signals.
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit

# Set to 1 to use Google Sheets, 0 to use mock CSV only.
USE_GOOGLE_SHEET=0

# --- Trading Parameters ---
INITIAL_CAPITAL=100000
RISK_PER_TRADE_PCT=0.01
BROKERAGE_PER_TRADE_INR=40
SLIPPAGE_PCT=0.0005
ML_CONFIDENCE_THRESHOLD=0.7
MAX_OPEN_POSITIONS=5
MAX_POSITION_PCT_CAPITAL=0.2

# --- ML Parameters ---
RF_N_ESTIMATORS=200

# --- yfinance Cache ---
YF_CACHE_SECONDS=45

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
